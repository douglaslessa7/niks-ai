{
  "expo": {
    "name": "NIKS AI",
    "slug": "niks-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1A1A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.niksai.app",
      "entitlements": {
        "aps-environment": "development"
      },
      "infoPlist": {
        "NSCameraUsageDescription": "O NIKS AI precisa da câmera para analisar sua pele e suas refeições.",
        "NSPhotoLibraryUsageDescription": "O NIKS AI precisa acessar suas fotos para análise de pele."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#1A1A1A"
      },
      "package": "com.niksai.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      [
        "expo-image-picker",
        {
          "photosPermission": "O NIKS AI precisa acessar suas fotos."
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.436683236946-36te4gp3c6eid9frheokli00j0pnocd4"
        }
      ],
      [
        "expo-notifications",
        {
          "iosDisplayInForeground": true
        }
      ]
    ],
    "scheme": "niks-ai",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ec0c225d-93a0-4722-b0b0-920b86209e3e"
      }
    },
    "owner": "douglessa"
  }
}